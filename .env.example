# Miku Server Configuration
SERVER_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/miku
DATABASE_USERNAME=miku
DATABASE_PASSWORD=change_this_password

# JWT (MUST change in production)
JWT_SECRET=generate-a-secure-random-string-min-32-chars
JWT_ISSUER=miku-server
JWT_AUDIENCE=miku-client
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# CORS (comma-separated origins)
CORS_ORIGINS=https://your-domain.com,https://your-domain.com

# Extensions
EXTENSIONS_DIR=extensions

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_MINUTES=30

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change_this_access_key
MINIO_SECRET_KEY=change_this_secret_key
MINIO_BUCKET=miku-storage

# Argon2id
ARGON2_ITERATIONS=3
ARGON2_MEMORY=65536
ARGON2_PARALLELISM=4
